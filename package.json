{
  "name": "root-editor",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm build:watch\" \"pnpm -F site dev\"",
    "dev:ng": "pnpm -F @agent-arts/editor build && concurrently \"pnpm build:watch\" \"pnpm -F site-ng start\"",
    "build": "pnpm -F site build",
    "build:ng": "pnpm -F site-ng build",
    "build:lib": "pnpm -F @agent-arts/editor build",
    "build:watch": "pnpm -F @agent-arts/editor build:watch",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "less": "^4.6.4",
    "vitepress": "2.0.0-alpha.17"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
